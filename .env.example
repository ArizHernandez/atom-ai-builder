# ─── Required ─────────────────────────────────────────────────────────────────
# OpenAI API Key — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ─── Telegram Bot (optional — for +10 bonus points) ───────────────────────────
# 1. Open Telegram → search @BotFather → /newbot
# 2. Follow the steps to create a bot
# 3. Copy the token here
TELEGRAM_BOT_TOKEN=123456789:ABC-DEF...

# ─── App URL (needed to register Telegram webhook) ────────────────────────────
# Leave empty for local dev (use ngrok instead)
# In Vercel this is set automatically as VERCEL_URL
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
